{
    "name": "hephaestus",
    "version": "1.0.0",
    "devDependencies": {
        "@eslint/js": "^9.39.3",
        "@tsconfig/svelte": "^5.0.8",
        "@types/chrome": "^0.1.37",
        "@types/node": "^24.11.0",
        "@wxt-dev/module-svelte": "^2.0.4",
        "eslint": "^9.39.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.15.0",
        "globals": "^17.3.0",
        "prettier": "^3.8.1",
        "pretty-quick": "^4.2.2",
        "simple-git-hooks": "^2.13.1",
        "svelte": "^5.53.6",
        "svelte-check": "^4.4.4",
        "tslib": "^2.8.1",
        "typescript-eslint": "^8.56.1",
        "wxt": "^0.20.18"
    },
    "private": true,
    "scripts": {
        "dev": "wxt",
        "dev:firefox": "wxt -b firefox",
        "build": "wxt build",
        "build:firefox": "wxt build -b firefox",
        "zip": "wxt zip",
        "zip:firefox": "wxt zip -b firefox",
        "check": "svelte-check --tsconfig ./tsconfig.json",
        "lint": "eslint ."
    },
    "simple-git-hooks": {
        "pre-commit": "bun pretty-quick --staged; bun eslint . --fix",
        "post-merge": "bun install",
        "post-checkout": "bun install"
    },
    "type": "module"
}
